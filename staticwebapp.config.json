{
    "navigationFallback": {
        "rewrite": "/index.html"
    },
    "routes" :[
        {
            "route": "/todo",
            "allowedRoles": ["authenticated"]
        }
    ],
    "responseOverrides": {
        "401": {
            
            "statusCode": 302,
            "redirect": "/.auth/login/aad"
        }
    },
    "auth": {
        "identityProviders": {
            "azureActiveDirectory": {
                "registration": {
                    "openIdIssuer": "https://TodoAppUsers.ciamlogin.com/bc4899c5-a308-4874-b570-d33b01a4d30d/v2.0",
                    "clientIdSettingName": "AZURE_CLIENT_ID",
                    "clientSecretSettingName": "AZURE_CLIENT_SECRET"
                }
            }
        }
    }
}